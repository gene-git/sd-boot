#!/usr/bin/bash
#
# Developer test builds
# 
cd ./build
echo "Debug :"
cmake -S ../ -B debug -DCMAKE_BUILD_TYPE=Debug -DCMAKE_INSTALL_PREFIX=/usr
cmake --build debug

echo "None (arch) :"
cmake -S ../ -B none -DCMAKE_BUILD_TYPE=None -DCMAKE_INSTALL_PREFIX=/usr
cmake --build none

#
# install - debug has static linking
# Since LD_LIBRARY_PATH are not passed down to
# kernel-install plugins to minimize risk.
#
echo "Installing:"
test_root="../tests/Testing/__root__"
DESTDIR="$test_root" cmake --install debug 
#DESTDIR="$test_root" cmake --install build/none 
